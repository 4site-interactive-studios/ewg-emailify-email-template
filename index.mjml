			</mj-column>
		</mj-section>
		<mj-section background-color="#ebebeb" padding="32px">
			<mj-column vertical-align="middle" width="576px">
				<mj-text align="center" color="#000000" font-size="13px" font-weight="700" line-height="185%" padding-bottom="8px">
					<p style="Margin:0;"><span style="font-weight:400;">Unsubscribe </span>| <a href="https://act.ewg.org/a/ewg-supporter-portal?secureToken=SampleEmailToken&nvep=&hmac=&emci=c973bf0e-bd0d-f111-a69a-000d3a57593f&emdi=ea000000-0000-0000-0000-000000000001&ceid=" style="color:#000000;text-decoration:none;" target="_blank">MANAGE PREFERENCES</a></p>
