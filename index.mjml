		<mj-section background-url="https://prod.cdn.everyaction.com/images/van/EWG/EWG/1/71381/images/emailify/5875a0c66fa6021a789bfa45c2559390.jpg" background-size="cover" background-repeat="no-repeat" background-position="center center" padding="16px 0px 380px 0px" text-align="center">
			<mj-column vertical-align="top" width="100%" padding="24px">
				<mj-text align="center" color="#2b2b2b" font-size="30px" line-height="130%" padding-bottom="24px">
					<p style="Margin:0;">Trump administration backs Bayer in Supreme Court fight, putting corporate interests over Roundup victims</p>
				</mj-text>
				<mj-button align="center" background-color="#203a3b" color="#ffffff" href="https://act.ewg.org/nrfMs7W5QU6qMaHkaV4lMg2?sourceid=1023696&utm_source=newsletter&utm_campaign=202602FebNews7&utm_medium=email&utm_content=default&nvep=&hmac=&emci=c973bf0e-bd0d-f111-a69a-000d3a57593f&emdi=ea000000-0000-0000-0000-000000000001&ceid=" width="154px">Read More</mj-button>
			</mj-column>
		</mj-section>
		<mj-section background-url="https://prod.cdn.everyaction.com/images/van/EWG/EWG/1/71381/images/emailify/e3fe1bff9a3f0985d65823a17dd40c35.jpg" background-size="cover" background-repeat="no-repeat" background-position="center center" padding="32px">
			<mj-column vertical-align="middle" width="576px">
				<mj-text align="left" color="#ffffff" font-size="35px" line-height="129%" padding-bottom="16px">
					<p style="Margin:0;">EWG'S 30TH ANNIVERSARY</p>
				</mj-text>
				<mj-text align="left" color="#ffffff" font-size="20px" line-height="140%" padding-bottom="16px">
					<p style="Margin:0;">EWG is celebrating 30 years of helping you to protect your health and environment. Individuals like you account for more than half of EWG's revenue and are essential to our success. <a href="https://act.ewg.org/O6Wq1SkLXEam4cmOkmwkyA2?sourceid=1022286&utm_source=newsletter&utm_campaign=202401Newsletter8&utm_medium=email&utm_content=default&nvep=&hmac=&emci=e14c20b5-bd0d-f111-a69a-000d3a57593f&emdi=ea000000-0000-0000-0000-000000000001&ceid=" style="font-weight:700;color:#009a4f;text-decoration:none;" target="_blank">Help us celebrate this anniversary and fund the work you count on with a donation today.</a></p>
				</mj-text>
				<mj-text align="left" color="#009a4f" font-size="20px" font-weight="700" line-height="140%" padding-bottom="16px">
					<p style="Margin:0;">CAN WE COUNT ON YOU TO JOIN OUR COMMUNITY OF OVER 400,000 SUPPORTERS TODAY?</p>
				</mj-text>
				<mj-text align="left" color="#ffffff" font-size="20px" line-height="140%" padding-bottom="16px">
					<p style="Margin:0;">Any amount makes a difference.</p>
				</mj-text>
				<mj-spacer height="8px" padding-bottom="16px"></mj-spacer>
				<mj-button align="center" background-color="#009a4f" color="#ffffff" font-size="13px" letter-spacing="1.95px" href="https://act.ewg.org/O6Wq1SkLXEam4cmOkmwkyA2?sourceid=1022286&utm_source=newsletter&utm_campaign=202401Newsletter8&utm_medium=email&utm_content=default&nvep=&hmac=&emci=e14c20b5-bd0d-f111-a69a-000d3a57593f&emdi=ea000000-0000-0000-0000-000000000001&ceid=" inner-padding="25px 0px 25px 0px" width="187px">Donate Now</mj-button>
			</mj-column>
		</mj-section>
		<mj-section background-color="#009a4f" padding="16px 32px">
			<mj-column vertical-align="middle" width="576px">
				<mj-text align="center" color="#ffffff" font-size="25px" font-weight="700" line-height="128%" text-transform="uppercase">
					<p style="Margin:0;">Know your environment. <br/>Protect your health.</p>
				</mj-text>
			</mj-column>
		</mj-section>
